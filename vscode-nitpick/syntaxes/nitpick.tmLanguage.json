{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Nitpick",
    "scopeName": "source.npk",
    "patterns": [
        { "include": "#comments" },
        { "include": "#preprocessor" },
        { "include": "#magic-constants" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#borrow-annotations" },
        { "include": "#function-declaration" },
        { "include": "#danger-keywords" },
        { "include": "#warning-keywords" },
        { "include": "#failsafe" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#builtins" },
        { "include": "#operators" },
        { "include": "#variables" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.npk",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.npk",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "preprocessor": {
            "patterns": [
                {
                    "name": "keyword.control.directive.npk",
                    "match": "%(?:define|undef|macro|endmacro|ifdef|ifndef|else|endif|include|rep|endrep|push|pop|assign|rotate)\\b"
                },
                {
                    "comment": "Macro parameter references: %1, %0, %*, #%1, ##",
                    "name": "variable.parameter.macro.npk",
                    "match": "(?:#%\\d+|##|%(?:\\*|\\d+))"
                }
            ]
        },
        "magic-constants": {
            "patterns": [
                {
                    "name": "constant.language.magic.npk",
                    "match": "\\b(__FILE__|__LINE__|__COUNTER__)\\b"
                }
            ]
        },
        "function-declaration": {
            "patterns": [
                {
                    "comment": "func:name pattern — highlights func as keyword and name as function",
                    "match": "\\b((?:pub|inline|noinline|async|comptime|extern)\\s+)*(func)(:)(\\w+)",
                    "captures": {
                        "1": { "name": "storage.modifier.npk" },
                        "2": { "name": "keyword.declaration.function.npk" },
                        "3": { "name": "punctuation.separator.npk" },
                        "4": { "name": "entity.name.function.npk" }
                    }
                }
            ]
        },
        "danger-keywords": {
            "patterns": [
                {
                    "comment": "Safety opt-out: manual memory (no GC)",
                    "name": "keyword.danger.memory.npk",
                    "match": "\\b(wild|wildx)\\b"
                },
                {
                    "comment": "Safety opt-out: raw unwrap bypasses Result safety",
                    "name": "keyword.danger.raw.npk",
                    "match": "\\braw\\b"
                },
                {
                    "comment": "Safety opt-out: drop discards Result",
                    "name": "keyword.danger.drop.npk",
                    "match": "\\bdrop\\b"
                },
                {
                    "comment": "Safety opt-out: _! raw shorthand, _? drop shorthand",
                    "name": "keyword.danger.shorthand.npk",
                    "match": "_[!?]"
                },
                {
                    "comment": "Safety opt-out: sys syscall with any bang tier",
                    "name": "keyword.danger.syscall.npk",
                    "match": "\\bsys\\s*!{1,3}\\s*(?=\\()"
                },
                {
                    "comment": "Failsafe call operator !!! (force-crash on error)",
                    "name": "keyword.danger.failsafe-call.npk",
                    "match": "!!!(?!=)"
                }
            ]
        },
        "warning-keywords": {
            "patterns": [
                {
                    "comment": "Error-aware: defaults keyword — scoped fallback",
                    "name": "keyword.warning.defaults.npk",
                    "match": "\\bdefaults\\b"
                },
                {
                    "comment": "Error-aware: ?| operator — scoped fallback shorthand",
                    "name": "keyword.warning.defaults-op.npk",
                    "match": "\\?\\|"
                },
                {
                    "comment": "Error-aware: ok — acknowledge value may be unknown/error",
                    "name": "keyword.warning.ok.npk",
                    "match": "\\bok\\b"
                },
                {
                    "comment": "Error-aware: failsafe — required error handler",
                    "name": "keyword.warning.failsafe.npk",
                    "match": "\\bfailsafe\\b"
                }
            ]
        },
        "failsafe": {
            "patterns": [
                {
                    "comment": "failsafe block — required error handler (kept for compat)",
                    "name": "keyword.warning.failsafe.npk",
                    "match": "\\bfailsafe\\b"
                },
                {
                    "comment": "Failsafe call operator !!! (danger)",
                    "name": "keyword.danger.failsafe-call.npk",
                    "match": "!!!(?!=)"
                }
            ]
        },
        "borrow-annotations": {
            "patterns": [
                {
                    "comment": "$$i (immutable borrow), $$m (mutable borrow)",
                    "name": "storage.modifier.borrow.npk",
                    "match": "\\$\\$(i|m)\\b"
                },
                {
                    "comment": "$ as borrow/iteration variable",
                    "name": "variable.language.iterator.npk",
                    "match": "\\$(?![a-zA-Z$])"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.flow.npk",
                    "match": "\\b(if|else|while|for|till|loop|when|then|end|pick|fall|break|continue|in)\\b"
                },
                {
                    "name": "keyword.control.return.npk",
                    "match": "\\b(pass|fail|return|exit)\\b"
                },
                {
                    "name": "keyword.control.async.npk",
                    "match": "\\b(async|await|catch)\\b"
                },
                {
                    "name": "keyword.declaration.npk",
                    "match": "\\b(func|struct|enum|trait|impl|opaque|mod|Type|Rules)\\b"
                },
                {
                    "name": "storage.modifier.npk",
                    "match": "\\b(pub|extern|const|fixed|comptime|inline|noinline|move|defer|dyn|macro|derive)\\b"
                },
                {
                    "name": "keyword.other.npk",
                    "match": "\\b(use|as|is|cfg|requires|ensures|invariant|prove|assert_static|limit)\\b"
                },
                {
                    "name": "keyword.memory.npk",
                    "match": "\\b(stack|gc|relaxed|acquire|release|acq_rel|seq_cst)\\b"
                },
                {
                    "name": "keyword.other.stream.npk",
                    "match": "\\b(stream|pipe|process|buffer|debug)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "comment": "Standard integer types",
                    "name": "storage.type.integer.npk",
                    "match": "\\b(int(?:1|2|4|8|16|32|64|128|256|512|1024|2048|4096)|uint(?:1|2|4|8|16|32|64|128|256|512|1024|2048|4096))\\b"
                },
                {
                    "comment": "Floating point types",
                    "name": "storage.type.float.npk",
                    "match": "\\b(flt32|flt64|flt128|flt256|flt512|fix256)\\b"
                },
                {
                    "comment": "Balanced ternary types",
                    "name": "storage.type.ternary.npk",
                    "match": "\\b(tbb8|tbb16|tbb32|tbb64|trit|tryte|nit|nyte)\\b"
                },
                {
                    "comment": "Fraction types",
                    "name": "storage.type.fraction.npk",
                    "match": "\\b(frac8|frac16|frac32|frac64)\\b"
                },
                {
                    "comment": "Twisted floating point types",
                    "name": "storage.type.tfp.npk",
                    "match": "\\b(tfp32|tfp64)\\b"
                },
                {
                    "comment": "Vector, matrix, tensor types",
                    "name": "storage.type.composite.npk",
                    "match": "\\b(vec2|vec3|vec9|matrix|tmatrix|tensor|ttensor|array|binary)\\b"
                },
                {
                    "comment": "Core types: bool, string, object, unknown, any, Result",
                    "name": "storage.type.core.npk",
                    "match": "\\b(bool|string|obj|unknown|any|Result)\\b"
                },
                {
                    "comment": "Special value constants: NIL, NULL, ERR",
                    "name": "constant.language.nil.npk",
                    "match": "\\b(NIL|NULL|ERR)\\b"
                }
            ]
        },
        "builtins": {
            "patterns": [
                {
                    "name": "support.function.builtin.npk",
                    "match": "\\b(print|println|stderr_write|stddbg_write|stdout_write|stdin_read_line|stdin_read_all|assert|sizeof|typeof|alignof|offsetof)\\b"
                },
                {
                    "comment": "Collection builtins: stack and hash table",
                    "name": "support.function.collection.npk",
                    "match": "\\b(astack|apush|apop|apeek|acap|asize|afits|atype|ahash|ahset|ahget|ahcount|ahsize|ahfits|ahtype|ahdelete|ahhas|ahclear|ahkeys)\\b"
                },
                {
                    "comment": "@intrinsics: cast, sizeof, etc.",
                    "name": "support.function.intrinsic.npk",
                    "match": "@(?:cast|cast_unchecked|sizeof|alignof|typeof|offsetof|assert|likely|unlikely|prefetch|unreachable|breakpoint|trap|simd_\\w+)\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.npk",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.npk",
                            "match": "\\\\(n|t|r|\\\\|\"|'|0)"
                        },
                        {
                            "name": "constant.character.escape.npk",
                            "match": "\\\\x[0-9A-Fa-f]{2}"
                        },
                        {
                            "name": "constant.character.escape.npk",
                            "match": "\\\\u[0-9A-Fa-f]{4}"
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.npk",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.npk",
                            "match": "\\\\(n|t|r|\\\\|\"|'|0)"
                        }
                    ]
                },
                {
                    "name": "string.quoted.backtick.npk",
                    "begin": "`",
                    "end": "`",
                    "patterns": [
                        {
                            "name": "variable.other.interpolation.npk",
                            "match": "&\\{[^}]+\\}"
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.npk",
                    "match": "\\b0[xX][0-9A-Fa-f_]+\\b"
                },
                {
                    "name": "constant.numeric.binary.npk",
                    "match": "\\b0[bB][01_]+\\b"
                },
                {
                    "name": "constant.numeric.octal.npk",
                    "match": "\\b0[oO][0-7_]+\\b"
                },
                {
                    "name": "constant.numeric.float.npk",
                    "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9_]+)?\\b"
                },
                {
                    "name": "constant.numeric.integer.npk",
                    "match": "\\b[0-9][0-9_]*\\b"
                },
                {
                    "name": "constant.language.boolean.npk",
                    "match": "\\b(true|false)\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "comment": "Result/Option unwrap and safe navigation operators",
                    "name": "keyword.operator.unwrap.npk",
                    "match": "\\?!|\\?\\.|\\.\\?|\\?\\?|\\?"
                },
                {
                    "name": "keyword.operator.comparison.npk",
                    "match": "<=>|==|!=|<=|>=|<|>"
                },
                {
                    "name": "keyword.operator.logical.npk",
                    "match": "&&|\\|\\||!"
                },
                {
                    "name": "keyword.operator.arithmetic.npk",
                    "match": "[+\\-*/%]"
                },
                {
                    "name": "keyword.operator.bitwise.npk",
                    "match": "&|\\||\\^|~|<<|>>"
                },
                {
                    "name": "keyword.operator.assignment.npk",
                    "match": "=|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>="
                },
                {
                    "name": "keyword.operator.arrow.npk",
                    "match": "->|<-|=>"
                },
                {
                    "name": "keyword.operator.pipe.npk",
                    "match": "\\|>|<\\|"
                },
                {
                    "name": "punctuation.separator.npk",
                    "match": ":"
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "comment": "Type:name variable declaration pattern",
                    "match": "\\b([A-Z][a-zA-Z0-9_]*)(:)([a-zA-Z_][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": { "name": "storage.type.npk" },
                        "2": { "name": "punctuation.separator.npk" },
                        "3": { "name": "variable.other.declaration.npk" }
                    }
                },
                {
                    "comment": "Function call",
                    "name": "entity.name.function.call.npk",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
                },
                {
                    "name": "variable.other.npk",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
                }
            ]
        }
    }
}