{
    "name": "aria-language",
    "displayName": "Nitpick Language Support",
    "description": "Syntax highlighting and language support for the Nitpick programming language",
    "version": "0.2.13",
    "publisher": "alternative-intelligence",
    "repository": {
        "type": "git",
        "url": "https://github.com/alternative-intelligence-cp/nitpick-tools"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [
            {
                "id": "aria",
                "aliases": [
                    "Nitpick",
                    "aria"
                ],
                "extensions": [
                    ".npk"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "aria",
                "scopeName": "source.npk",
                "path": "./syntaxes/nitpick.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "aria",
                "path": "./snippets/nitpick.json"
            }
        ],
        "configurationDefaults": {
            "editor.tokenColorCustomizations": {
                "textMateRules": [
                    {
                        "scope": [
                            "keyword.danger.memory.npk",
                            "keyword.danger.raw.npk",
                            "keyword.danger.drop.npk",
                            "keyword.danger.shorthand.npk",
                            "keyword.danger.syscall.npk",
                            "keyword.danger.failsafe-call.npk"
                        ],
                        "settings": {
                            "foreground": "#FF4444",
                            "fontStyle": "bold"
                        }
                    },
                    {
                        "scope": [
                            "keyword.warning.defaults.npk",
                            "keyword.warning.defaults-op.npk",
                            "keyword.warning.ok.npk",
                            "keyword.warning.failsafe.npk"
                        ],
                        "settings": {
                            "foreground": "#FFCC00",
                            "fontStyle": "bold"
                        }
                    }
                ]
            }
        }
    }
}