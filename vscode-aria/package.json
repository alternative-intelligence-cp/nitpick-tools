{
    "name": "aria-language",
    "displayName": "Aria Language Support",
    "description": "Syntax highlighting and language support for the Aria programming language",
    "version": "0.2.13",
    "publisher": "alternative-intelligence",
    "repository": {
        "type": "git",
        "url": "https://github.com/alternative-intelligence-cp/aria-tools"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Programming Languages"
    ],
    "contributes": {
        "languages": [
            {
                "id": "aria",
                "aliases": [
                    "Aria",
                    "aria"
                ],
                "extensions": [
                    ".aria"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "aria",
                "scopeName": "source.aria",
                "path": "./syntaxes/aria.tmLanguage.json"
            }
        ],
        "snippets": [
            {
                "language": "aria",
                "path": "./snippets/aria.json"
            }
        ],
        "configurationDefaults": {
            "editor.tokenColorCustomizations": {
                "textMateRules": [
                    {
                        "scope": [
                            "keyword.danger.memory.aria",
                            "keyword.danger.raw.aria",
                            "keyword.danger.drop.aria",
                            "keyword.danger.shorthand.aria",
                            "keyword.danger.syscall.aria",
                            "keyword.danger.failsafe-call.aria"
                        ],
                        "settings": {
                            "foreground": "#FF4444",
                            "fontStyle": "bold"
                        }
                    },
                    {
                        "scope": [
                            "keyword.warning.defaults.aria",
                            "keyword.warning.defaults-op.aria",
                            "keyword.warning.ok.aria",
                            "keyword.warning.failsafe.aria"
                        ],
                        "settings": {
                            "foreground": "#FFCC00",
                            "fontStyle": "bold"
                        }
                    }
                ]
            }
        }
    }
}