{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Aria",
    "scopeName": "source.aria",
    "patterns": [
        { "include": "#comments" },
        { "include": "#preprocessor" },
        { "include": "#magic-constants" },
        { "include": "#strings" },
        { "include": "#numbers" },
        { "include": "#borrow-annotations" },
        { "include": "#function-declaration" },
        { "include": "#danger-keywords" },
        { "include": "#warning-keywords" },
        { "include": "#failsafe" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#builtins" },
        { "include": "#operators" },
        { "include": "#variables" }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.aria",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.aria",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },
        "preprocessor": {
            "patterns": [
                {
                    "name": "keyword.control.directive.aria",
                    "match": "%(?:define|undef|macro|endmacro|ifdef|ifndef|else|endif|include|rep|endrep|push|pop|assign|rotate)\\b"
                },
                {
                    "comment": "Macro parameter references: %1, %0, %*, #%1, ##",
                    "name": "variable.parameter.macro.aria",
                    "match": "(?:#%\\d+|##|%(?:\\*|\\d+))"
                }
            ]
        },
        "magic-constants": {
            "patterns": [
                {
                    "name": "constant.language.magic.aria",
                    "match": "\\b(__FILE__|__LINE__|__COUNTER__)\\b"
                }
            ]
        },
        "function-declaration": {
            "patterns": [
                {
                    "comment": "func:name pattern — highlights func as keyword and name as function",
                    "match": "\\b((?:pub|priv|inline|noinline|async|comptime|extern)\\s+)*(func)(:)(\\w+)",
                    "captures": {
                        "1": { "name": "storage.modifier.aria" },
                        "2": { "name": "keyword.declaration.function.aria" },
                        "3": { "name": "punctuation.separator.aria" },
                        "4": { "name": "entity.name.function.aria" }
                    }
                }
            ]
        },
        "danger-keywords": {
            "patterns": [
                {
                    "comment": "Safety opt-out: manual memory (no GC)",
                    "name": "keyword.danger.memory.aria",
                    "match": "\\b(wild|wildx)\\b"
                },
                {
                    "comment": "Safety opt-out: raw unwrap bypasses Result safety",
                    "name": "keyword.danger.raw.aria",
                    "match": "\\braw\\b"
                },
                {
                    "comment": "Safety opt-out: drop discards Result",
                    "name": "keyword.danger.drop.aria",
                    "match": "\\bdrop\\b"
                },
                {
                    "comment": "Safety opt-out: _! raw shorthand, _? drop shorthand",
                    "name": "keyword.danger.shorthand.aria",
                    "match": "_[!?]"
                },
                {
                    "comment": "Safety opt-out: sys syscall with any bang tier",
                    "name": "keyword.danger.syscall.aria",
                    "match": "\\bsys\\s*!{1,3}\\s*(?=\\()"
                },
                {
                    "comment": "Failsafe call operator !!! (force-crash on error)",
                    "name": "keyword.danger.failsafe-call.aria",
                    "match": "!!!(?!=)"
                }
            ]
        },
        "warning-keywords": {
            "patterns": [
                {
                    "comment": "Error-aware: defaults keyword — scoped fallback",
                    "name": "keyword.warning.defaults.aria",
                    "match": "\\bdefaults\\b"
                },
                {
                    "comment": "Error-aware: ?| operator — scoped fallback shorthand",
                    "name": "keyword.warning.defaults-op.aria",
                    "match": "\\?\\|"
                },
                {
                    "comment": "Error-aware: ok — acknowledge value may be unknown/error",
                    "name": "keyword.warning.ok.aria",
                    "match": "\\bok\\b"
                },
                {
                    "comment": "Error-aware: failsafe — required error handler",
                    "name": "keyword.warning.failsafe.aria",
                    "match": "\\bfailsafe\\b"
                }
            ]
        },
        "failsafe": {
            "patterns": [
                {
                    "comment": "failsafe block — required error handler (kept for compat)",
                    "name": "keyword.warning.failsafe.aria",
                    "match": "\\bfailsafe\\b"
                },
                {
                    "comment": "Failsafe call operator !!! (danger)",
                    "name": "keyword.danger.failsafe-call.aria",
                    "match": "!!!(?!=)"
                }
            ]
        },
        "borrow-annotations": {
            "patterns": [
                {
                    "comment": "$mut, $ref borrow annotations",
                    "name": "storage.modifier.borrow.aria",
                    "match": "\\$(mut|ref)\\b"
                },
                {
                    "comment": "$ as borrow/iteration variable",
                    "name": "variable.language.iterator.aria",
                    "match": "\\$(?![a-zA-Z])"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.flow.aria",
                    "match": "\\b(if|else|while|for|till|loop|when|then|end|pick|fall|break|continue|match|in)\\b"
                },
                {
                    "name": "keyword.control.return.aria",
                    "match": "\\b(pass|fail|return)\\b"
                },
                {
                    "name": "keyword.control.async.aria",
                    "match": "\\b(async|await|catch)\\b"
                },
                {
                    "name": "keyword.declaration.aria",
                    "match": "\\b(func|struct|enum|trait|impl|opaque|mod)\\b"
                },
                {
                    "name": "storage.modifier.aria",
                    "match": "\\b(pub|extern|const|fixed|comptime|inline|noinline|move|defer|dyn)\\b"
                },
                {
                    "name": "keyword.other.aria",
                    "match": "\\b(use|as|is|cfg|requires|ensures|invariant)\\b"
                },
                {
                    "name": "keyword.memory.aria",
                    "match": "\\b(stack|gc|relaxed|acquire|release|acq_rel|seq_cst)\\b"
                },
                {
                    "name": "keyword.other.stream.aria",
                    "match": "\\b(stream|pipe|process|buffer|debug)\\b"
                }
            ]
        },
        "types": {
            "patterns": [
                {
                    "comment": "Standard integer types",
                    "name": "storage.type.integer.aria",
                    "match": "\\b(int(?:1|2|4|8|16|32|64|128|256|512|1024|2048|4096)|uint(?:1|2|4|8|16|32|64|128|256|512|1024|2048|4096))\\b"
                },
                {
                    "comment": "Floating point types",
                    "name": "storage.type.float.aria",
                    "match": "\\b(flt32|flt64|flt128|flt256|flt512|fix256)\\b"
                },
                {
                    "comment": "Balanced ternary types",
                    "name": "storage.type.ternary.aria",
                    "match": "\\b(tbb8|tbb16|tbb32|tbb64|trit|tryte|nit|nyte)\\b"
                },
                {
                    "comment": "Fraction types",
                    "name": "storage.type.fraction.aria",
                    "match": "\\b(frac8|frac16|frac32|frac64)\\b"
                },
                {
                    "comment": "Twisted floating point types",
                    "name": "storage.type.tfp.aria",
                    "match": "\\b(tfp32|tfp64)\\b"
                },
                {
                    "comment": "Vector, matrix, tensor types",
                    "name": "storage.type.composite.aria",
                    "match": "\\b(vec2|vec3|vec9|matrix|tmatrix|tensor|ttensor|array|binary)\\b"
                },
                {
                    "comment": "Core types: bool, string, object, unknown",
                    "name": "storage.type.core.aria",
                    "match": "\\b(bool|string|obj|unknown)\\b"
                },
                {
                    "comment": "NIL constant (null equivalent)",
                    "name": "constant.language.nil.aria",
                    "match": "\\bNIL\\b"
                }
            ]
        },
        "builtins": {
            "patterns": [
                {
                    "name": "support.function.builtin.aria",
                    "match": "\\b(print|println|eprint|eprintln|assert|sizeof|typeof|alignof)\\b"
                }
            ]
        },
        "strings": {
            "patterns": [
                {
                    "name": "string.quoted.double.aria",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.aria",
                            "match": "\\\\(n|t|r|\\\\|\"|'|0)"
                        },
                        {
                            "name": "constant.character.escape.aria",
                            "match": "\\\\x[0-9A-Fa-f]{2}"
                        },
                        {
                            "name": "constant.character.escape.aria",
                            "match": "\\\\u[0-9A-Fa-f]{4}"
                        }
                    ]
                },
                {
                    "name": "string.quoted.single.aria",
                    "begin": "'",
                    "end": "'",
                    "patterns": [
                        {
                            "name": "constant.character.escape.aria",
                            "match": "\\\\(n|t|r|\\\\|\"|'|0)"
                        }
                    ]
                },
                {
                    "name": "string.quoted.backtick.aria",
                    "begin": "`",
                    "end": "`",
                    "patterns": [
                        {
                            "name": "variable.other.interpolation.aria",
                            "match": "&\\{[^}]+\\}"
                        }
                    ]
                }
            ]
        },
        "numbers": {
            "patterns": [
                {
                    "name": "constant.numeric.hex.aria",
                    "match": "\\b0[xX][0-9A-Fa-f_]+\\b"
                },
                {
                    "name": "constant.numeric.binary.aria",
                    "match": "\\b0[bB][01_]+\\b"
                },
                {
                    "name": "constant.numeric.octal.aria",
                    "match": "\\b0[oO][0-7_]+\\b"
                },
                {
                    "name": "constant.numeric.float.aria",
                    "match": "\\b[0-9][0-9_]*\\.[0-9][0-9_]*([eE][+-]?[0-9_]+)?\\b"
                },
                {
                    "name": "constant.numeric.integer.aria",
                    "match": "\\b[0-9][0-9_]*\\b"
                },
                {
                    "name": "constant.language.boolean.aria",
                    "match": "\\b(true|false)\\b"
                }
            ]
        },
        "operators": {
            "patterns": [
                {
                    "comment": "Result/Option unwrap operators",
                    "name": "keyword.operator.unwrap.aria",
                    "match": "\\?!|\\?\\?|\\?"
                },
                {
                    "name": "keyword.operator.comparison.aria",
                    "match": "==|!=|<=|>=|<|>"
                },
                {
                    "name": "keyword.operator.logical.aria",
                    "match": "&&|\\|\\||!"
                },
                {
                    "name": "keyword.operator.arithmetic.aria",
                    "match": "[+\\-*/%]"
                },
                {
                    "name": "keyword.operator.bitwise.aria",
                    "match": "&|\\||\\^|~|<<|>>"
                },
                {
                    "name": "keyword.operator.assignment.aria",
                    "match": "=|\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>="
                },
                {
                    "name": "keyword.operator.arrow.aria",
                    "match": "->|=>"
                },
                {
                    "name": "punctuation.separator.aria",
                    "match": ":"
                }
            ]
        },
        "variables": {
            "patterns": [
                {
                    "comment": "Type:name variable declaration pattern",
                    "match": "\\b([A-Z][a-zA-Z0-9_]*)(:)([a-zA-Z_][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": { "name": "storage.type.aria" },
                        "2": { "name": "punctuation.separator.aria" },
                        "3": { "name": "variable.other.declaration.aria" }
                    }
                },
                {
                    "comment": "Function call",
                    "name": "entity.name.function.call.aria",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
                },
                {
                    "name": "variable.other.aria",
                    "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*\\b"
                }
            ]
        }
    }
}