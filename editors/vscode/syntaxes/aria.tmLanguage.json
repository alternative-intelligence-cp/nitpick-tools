{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "Aria",
    "scopeName": "source.aria",
    "patterns": [
        { "include": "#comments" },
        { "include": "#strings" },
        { "include": "#function-declarations" },
        { "include": "#variable-declarations" },
        { "include": "#numbers" },
        { "include": "#keywords" },
        { "include": "#types" },
        { "include": "#function-calls" },
        { "include": "#operators" },
        { "include": "#memory-qualifiers" },
        { "include": "#constants" }
    ],
    "repository": {

        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.aria",
                    "match": "//.*$"
                },
                {
                    "name": "comment.block.aria",
                    "begin": "/\\*",
                    "end": "\\*/"
                }
            ]
        },

        "strings": {
            "patterns": [
                {
                    "comment": "Template string with interpolation: `hello &{name}`",
                    "name": "string.template.aria",
                    "begin": "`",
                    "end": "`",
                    "patterns": [
                        {
                            "name": "meta.embedded.expression.aria",
                            "begin": "&\\{",
                            "end": "\\}",
                            "beginCaptures": {
                                "0": { "name": "punctuation.definition.template-expression.begin.aria" }
                            },
                            "endCaptures": {
                                "0": { "name": "punctuation.definition.template-expression.end.aria" }
                            },
                            "patterns": [{ "include": "$self" }]
                        },
                        {
                            "name": "constant.character.escape.aria",
                            "match": "\\\\."
                        }
                    ]
                },
                {
                    "name": "string.quoted.double.aria",
                    "begin": "\"",
                    "end": "\"",
                    "patterns": [
                        {
                            "name": "constant.character.escape.aria",
                            "match": "\\\\."
                        }
                    ]
                }
            ]
        },

        "function-declarations": {
            "comment": "Matches: [pub] func:name = ReturnType(params) { }",
            "patterns": [
                {
                    "name": "meta.function.declaration.aria",
                    "match": "\\b(func)\\s*(:)\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": { "name": "keyword.declaration.function.aria" },
                        "2": { "name": "punctuation.separator.function.aria" },
                        "3": { "name": "entity.name.function.aria" }
                    }
                }
            ]
        },

        "variable-declarations": {
            "comment": "Matches type:name declaration: int32:x, uint64:count, bool:flag",
            "patterns": [
                {
                    "name": "meta.variable.declaration.aria",
                    "match": "\\b(int8|int16|int32|int64|int128|uint8|uint16|uint32|uint64|uint128|flt32|flt64|bool|string|tbb8|tbb16|tbb32|tbb64|fix256|tfp64|frac8)\\s*(:)\\s*([a-zA-Z_][a-zA-Z0-9_]*)",
                    "captures": {
                        "1": { "name": "storage.type.aria" },
                        "2": { "name": "punctuation.separator.type.aria" },
                        "3": { "name": "variable.name.aria" }
                    }
                }
            ]
        },

        "numbers": {
            "patterns": [
                {
                    "comment": "Balanced ternary literals: 0t1T0 (T=-1, 1=+1, 0=0)",
                    "name": "constant.numeric.ternary.aria",
                    "match": "\\b0t[01T]+\\b"
                },
                {
                    "comment": "Balanced nonary literals: 0n4D (D=-4)",
                    "name": "constant.numeric.nonary.aria",
                    "match": "\\b0n[0-9A-D]+\\b"
                },
                {
                    "name": "constant.numeric.hex.aria",
                    "match": "\\b0[xX][0-9a-fA-F_]+\\b"
                },
                {
                    "name": "constant.numeric.binary.aria",
                    "match": "\\b0[bB][01_]+\\b"
                },
                {
                    "name": "constant.numeric.octal.aria",
                    "match": "\\b0[oO][0-7_]+\\b"
                },
                {
                    "comment": "Typed float literal: 3.14flt64, 0.5fix256, 1.5tf",
                    "name": "constant.numeric.float.typed.aria",
                    "match": "\\b(\\d[\\d_]*\\.\\d[\\d_]*(?:[eE][+-]?\\d[\\d_]*)?)(flt32|flt64|fix256|tf)\\b",
                    "captures": {
                        "1": { "name": "constant.numeric.float.aria" },
                        "2": { "name": "storage.type.numeric-suffix.aria" }
                    }
                },
                {
                    "comment": "Typed integer literal: 42i32, 100u64, 127tbb8",
                    "name": "constant.numeric.integer.typed.aria",
                    "match": "\\b(\\d[\\d_]*)(i8|i16|i32|i64|i128|u8|u16|u32|u64|u128|tbb8|tbb16|tbb32|tbb64)\\b",
                    "captures": {
                        "1": { "name": "constant.numeric.integer.aria" },
                        "2": { "name": "storage.type.numeric-suffix.aria" }
                    }
                },
                {
                    "comment": "Bare float (no suffix)",
                    "name": "constant.numeric.float.aria",
                    "match": "\\b\\d[\\d_]*\\.\\d[\\d_]*(?:[eE][+-]?\\d[\\d_]*)?\\b"
                },
                {
                    "comment": "Bare integer (no suffix)",
                    "name": "constant.numeric.integer.aria",
                    "match": "\\b\\d[\\d_]*\\b"
                }
            ]
        },

        "keywords": {
            "patterns": [
                {
                    "comment": "Return mechanisms — pass and fail are Aria's return/throw equivalents",
                    "name": "keyword.control.return.aria",
                    "match": "\\b(pass|fail)\\b"
                },
                {
                    "comment": "Control flow",
                    "name": "keyword.control.aria",
                    "match": "\\b(if|else|when|then|end|till|while|for|in|loop|pick|case|default|break|continue|fall|defer|async|await)\\b"
                },
                {
                    "comment": "TOS explicit bypass builtins — drop(), raw(), ok()",
                    "name": "support.function.builtin.aria",
                    "match": "\\b(drop|raw|ok)\\b(?=\\s*\\()"
                },
                {
                    "comment": "Standard output",
                    "name": "support.function.builtin.print.aria",
                    "match": "\\b(print|println)\\b(?=\\s*\\()"
                },
                {
                    "comment": "Module and FFI system",
                    "name": "keyword.declaration.module.aria",
                    "match": "\\b(use|extern|mod)\\b"
                },
                {
                    "comment": "Visibility modifier",
                    "name": "keyword.modifier.visibility.aria",
                    "match": "\\b(pub)\\b"
                },
                {
                    "comment": "Type / struct declaration",
                    "name": "keyword.declaration.aria",
                    "match": "\\b(struct|enum|trait|impl|type|const)\\b"
                },
                {
                    "comment": "Executable memory allocation mode (JIT, use wild for W^X)",
                    "name": "keyword.other.memory-mode.aria",
                    "match": "\\b(wild|wildx)\\b"
                },
                {
                    "comment": "Other language keywords",
                    "name": "keyword.other.aria",
                    "match": "\\b(as|is|ref|mut|move|copy|superpose|collapse)\\b"
                }
            ]
        },

        "types": {
            "patterns": [
                {
                    "comment": "TBB (Twisted Balanced Binary) — symmetric signed, ERR sentinel",
                    "name": "storage.type.tbb.aria",
                    "match": "\\b(tbb8|tbb16|tbb32|tbb64|tbb128|tbb256)\\b"
                },
                {
                    "comment": "Deterministic fixed-point and twisted-float",
                    "name": "storage.type.fixedpoint.aria",
                    "match": "\\b(fix256|tfp64|frac8)\\b"
                },
                {
                    "comment": "Balanced ternary/nonary scalars",
                    "name": "storage.type.balanced.aria",
                    "match": "\\b(trit|tryte|nit|nyte)\\b"
                },
                {
                    "comment": "Signed integers",
                    "name": "storage.type.integer.aria",
                    "match": "\\b(int8|int16|int32|int64|int128|int256|int512)\\b"
                },
                {
                    "comment": "Unsigned integers",
                    "name": "storage.type.unsigned.aria",
                    "match": "\\b(uint8|uint16|uint32|uint64|uint128|uint256|uint512)\\b"
                },
                {
                    "comment": "Floating-point",
                    "name": "storage.type.float.aria",
                    "match": "\\b(flt16|flt32|flt64|flt128)\\b"
                },
                {
                    "comment": "Primitive types",
                    "name": "storage.type.primitive.aria",
                    "match": "\\b(bool|string|void)\\b"
                },
                {
                    "comment": "Generic container types — only when followed by < to reduce false positives",
                    "name": "storage.type.generic.aria",
                    "match": "\\b(Result|Handle|arena|atomic|simd|quantum|complex)\\b(?=\\s*<)"
                }
            ]
        },

        "function-calls": {
            "patterns": [
                {
                    "name": "entity.name.function.call.aria",
                    "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
                }
            ]
        },

        "operators": {
            "patterns": [
                {
                    "comment": "Emphatic Result unwrap — triggers failsafe on error",
                    "name": "keyword.operator.result.emphatic-unwrap.aria",
                    "match": "\\?!"
                },
                {
                    "comment": "Unchecked explicit bypass",
                    "name": "keyword.operator.unchecked.aria",
                    "match": "!!!"
                },
                {
                    "comment": "Null/unknown coalescing",
                    "name": "keyword.operator.result.null-coalesce.aria",
                    "match": "\\?\\?"
                },
                {
                    "comment": "Safe Result unwrap with default: val ? default",
                    "name": "keyword.operator.result.safe-unwrap.aria",
                    "match": "(?<![?!])\\?(?![?!])"
                },
                {
                    "comment": "Range: .. (inclusive) and ... (exclusive)",
                    "name": "keyword.operator.range.aria",
                    "match": "\\.\\.\\.?"
                },
                {
                    "comment": "Pipeline operators |> and <|",
                    "name": "keyword.operator.pipeline.aria",
                    "match": "\\|>|<\\|"
                },
                {
                    "comment": "Three-way comparison <=>",
                    "name": "keyword.operator.spaceship.aria",
                    "match": "<=>"
                },
                {
                    "comment": "Dimensional type cast =>",
                    "name": "keyword.operator.dimensional-cast.aria",
                    "match": "=>"
                },
                {
                    "comment": "Blueprint pointer dereference <-ptr",
                    "name": "keyword.operator.dereference.aria",
                    "match": "<-"
                },
                {
                    "comment": "Blueprint pointer type annotation ->",
                    "name": "keyword.operator.pointer-type.aria",
                    "match": "->(?!=)"
                },
                {
                    "comment": "Compiler intrinsics: @cast<T>, @addr",
                    "name": "keyword.operator.intrinsic.aria",
                    "match": "@(?:cast|addr)\\b"
                },
                {
                    "comment": "Address-of / memory operator @",
                    "name": "keyword.operator.address.aria",
                    "match": "@"
                },
                {
                    "comment": "Pin operator — pins value at fixed address",
                    "name": "keyword.operator.pin.aria",
                    "match": "#"
                },
                {
                    "comment": "Safe reference operator $",
                    "name": "keyword.operator.safe-ref.aria",
                    "match": "\\$(?![{])"
                },
                {
                    "comment": "Implicit loop counter $",
                    "name": "variable.language.loop-counter.aria",
                    "match": "\\$(?![{])"
                },
                {
                    "comment": "Arithmetic",
                    "name": "keyword.operator.arithmetic.aria",
                    "match": "\\+(?![=])|(?<!<)(?<!-)(?<!-)(?<![^<]-)(?<![-<])-(?!>)(?![=])|(?<!\\*)/(?![/=])|(?<!/)\\*(?![=])|%(?![=])"
                },
                {
                    "comment": "Comparison",
                    "name": "keyword.operator.comparison.aria",
                    "match": "==|!=|<=(?!>)|>=|<(?![-=<|])|>(?![>=])"
                },
                {
                    "comment": "Logical",
                    "name": "keyword.operator.logical.aria",
                    "match": "&&|\\|\\||!(?![!=])"
                },
                {
                    "comment": "Bitwise",
                    "name": "keyword.operator.bitwise.aria",
                    "match": "&(?!&)|\\|(?!\\||>)|\\^|<<(?![=])|>>(?![=])|~"
                },
                {
                    "comment": "Assignment (must be after all compound operators)",
                    "name": "keyword.operator.assignment.aria",
                    "match": "\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>=|=(?![=>])"
                }
            ]
        },

        "memory-qualifiers": {
            "patterns": [
                {
                    "comment": "@wild, @gc, @stack, @wildx allocation qualifiers",
                    "name": "meta.memory.qualifier.aria",
                    "match": "(@)(wild|gc|stack|wildx)\\b",
                    "captures": {
                        "1": { "name": "keyword.operator.memory.aria" },
                        "2": { "name": "keyword.other.memory-mode.aria" }
                    }
                }
            ]
        },

        "constants": {
            "patterns": [
                {
                    "name": "constant.language.boolean.aria",
                    "match": "\\b(true|false)\\b"
                },
                {
                    "comment": "NIL — Aria's absence-of-value type (NOT a null pointer)",
                    "name": "constant.language.nil.aria",
                    "match": "\\bNIL\\b"
                },
                {
                    "comment": "NULL — C-style null pointer constant for @ pointer types",
                    "name": "constant.language.null.aria",
                    "match": "\\bNULL\\b"
                },
                {
                    "comment": "ERR — TBB/fix256 sticky error sentinel value",
                    "name": "constant.language.error-sentinel.aria",
                    "match": "\\bERR\\b"
                },
                {
                    "comment": "unknown — soft-error propagating state (division by zero, OOB, etc.)",
                    "name": "constant.language.unknown.aria",
                    "match": "\\bunknown\\b"
                }
            ]
        }

    }
}
