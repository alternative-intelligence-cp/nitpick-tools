{
    "name": "nitpick-lang",
    "displayName": "Nitpick Language Support",
    "description": "Language support for Nitpick - a systems programming language with TBB arithmetic and hybrid memory model",
    "version": "0.2.16",
    "publisher": "nitpick-lang",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/alternative-intelligence-cp/nitpick"
    },
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "Programming Languages",
        "Linters",
        "Formatters"
    ],
    "keywords": [
        "aria",
        "systems programming",
        "tbb",
        "memory safety"
    ],
    "main": "./out/extension.js",
    "activationEvents": [
        "onDebugResolve:aria"
    ],
    "contributes": {
        "languages": [
            {
                "id": "aria",
                "aliases": [
                    "Nitpick",
                    "aria"
                ],
                "extensions": [
                    ".aria",
                    ".npk"
                ],
                "configuration": "./language-configuration.json",
                "icon": {
                    "light": "./icons/aria-icon.png",
                    "dark": "./icons/aria-icon.png"
                }
            }
        ],
        "commands": [
            {
                "command": "nitpick.initProject",
                "title": "Nitpick: Initialize Project"
            }
        ],
        "grammars": [
            {
                "language": "aria",
                "scopeName": "source.aria",
                "path": "./syntaxes/aria.tmLanguage.json"
            }
        ],
        "configuration": {
            "type": "object",
            "title": "Nitpick Language Server",
            "properties": {
                "nitpick.server.path": {
                    "type": "string",
                    "default": "",
                    "description": "Path to nitpick-ls executable. If empty, uses bundled binary."
                },
                "nitpick.server.args": {
                    "type": "array",
                    "default": [],
                    "description": "Additional arguments to pass to nitpick-ls"
                },
                "nitpick.trace.server": {
                    "type": "string",
                    "enum": [
                        "off",
                        "messages",
                        "verbose"
                    ],
                    "default": "off",
                    "description": "Traces the communication between VS Code and the language server"
                },
                "nitpick.debugger.path": {
                    "type": "string",
                    "default": "",
                    "description": "Path to nitpick-dap executable. If empty, uses bundled binary or system PATH."
                },
                "nitpick.compiler.path": {
                    "type": "string",
                    "default": "",
                    "description": "Path to npkc executable. If empty, uses system PATH."
                }
            }
        },
        "debuggers": [
            {
                "type": "aria",
                "label": "Nitpick Debug",
                "languages": [
                    "aria"
                ],
                "configurationAttributes": {
                    "launch": {
                        "required": [
                            "program"
                        ],
                        "properties": {
                            "program": {
                                "type": "string",
                                "description": "Absolute path to the Nitpick program executable to debug.",
                                "default": "${workspaceFolder}/build/${fileBasenameNoExtension}"
                            },
                            "source": {
                                "type": "string",
                                "description": "Path to the .aria source file (for source mapping).",
                                "default": "${file}"
                            },
                            "stopOnEntry": {
                                "type": "boolean",
                                "description": "Stop at program entry point.",
                                "default": false
                            },
                            "cwd": {
                                "type": "string",
                                "description": "Working directory for the debuggee.",
                                "default": "${workspaceFolder}"
                            },
                            "args": {
                                "type": "array",
                                "items": {
                                    "type": "string"
                                },
                                "description": "Command line arguments for the debuggee.",
                                "default": []
                            },
                            "compileFirst": {
                                "type": "boolean",
                                "description": "Compile the source file with -g before launching.",
                                "default": true
                            }
                        }
                    }
                },
                "initialConfigurations": [
                    {
                        "type": "aria",
                        "request": "launch",
                        "name": "Debug Nitpick Program",
                        "program": "${workspaceFolder}/build/${fileBasenameNoExtension}",
                        "source": "${file}",
                        "stopOnEntry": false,
                        "compileFirst": true
                    }
                ],
                "configurationSnippets": [
                    {
                        "label": "Nitpick: Debug Program",
                        "description": "Launch and debug an Nitpick program",
                        "body": {
                            "type": "aria",
                            "request": "launch",
                            "name": "Debug ${1:program}",
                            "program": "^\"\\${workspaceFolder}/build/${1:program}\"",
                            "source": "^\"\\${file}\"",
                            "stopOnEntry": false,
                            "compileFirst": true
                        }
                    }
                ]
            }
        ],
        "configurationDefaults": {
            "editor.tokenColorCustomizations": {
                "textMateRules": [
                    {
                        "scope": [
                            "keyword.danger.memory.aria",
                            "keyword.danger.raw.aria",
                            "keyword.danger.drop.aria",
                            "keyword.danger.shorthand.aria",
                            "keyword.danger.syscall.aria",
                            "keyword.danger.failsafe-call.aria"
                        ],
                        "settings": {
                            "foreground": "#FF4444",
                            "fontStyle": "bold"
                        }
                    },
                    {
                        "scope": [
                            "keyword.warning.defaults.aria",
                            "keyword.warning.defaults-op.aria",
                            "keyword.warning.ok.aria",
                            "keyword.warning.failsafe.aria"
                        ],
                        "settings": {
                            "foreground": "#FFCC00",
                            "fontStyle": "bold"
                        }
                    }
                ]
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile",
        "lint": "eslint src --ext ts",
        "package": "vsce package"
    },
    "dependencies": {
        "vscode-languageclient": "^9.0.1"
    },
    "devDependencies": {
        "@types/node": "^20.x",
        "@types/vscode": "^1.80.0",
        "@typescript-eslint/eslint-plugin": "^6.x",
        "@typescript-eslint/parser": "^6.x",
        "eslint": "^8.x",
        "typescript": "^5.2.0",
        "@vscode/vsce": "^2.21.0"
    }
}